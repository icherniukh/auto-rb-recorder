<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for PyInstaller --onefile: the bundled Python.framework is signed
         by a different Team ID (Python Software Foundation) than this app's signing
         identity. Hardened Runtime blocks cross-Team-ID library loading by default. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
